{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug CLI",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/core/mesanote/cli.py",
            "args": "${input:cliArgs}",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug VS Code Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "${workspaceFolder}/extensions/vscode/test_workspace",
                "--disable-extensions",
                "--extensionDevelopmentPath=${workspaceFolder}/extensions/vscode"
            ]
        }
    ],
    "inputs": [
        {
            "id": "cliArgs",
            "type": "promptString",
            "description": "Enter args"
        }
    ]
}